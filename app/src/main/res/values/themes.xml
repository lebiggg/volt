<?xml version="1.0" encoding="utf-8"?>
<!--
    Volt — Theme XML host pour l'Activity Compose.
    Le rendu réel est piloté par `VoltTheme` (Material You dynamique) côté Compose ;
    ce theme XML sert uniquement de "splash" durant le warm-up de l'Activity.
    Background = couleur surface du système (transparent serait FOUC sur dark mode).
-->
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.Volt" parent="android:Theme.DeviceDefault.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:enforceStatusBarContrast" tools:targetApi="29">false</item>
        <item name="android:enforceNavigationBarContrast" tools:targetApi="29">false</item>
    </style>

</resources>
